{
	"engines": {
		"node": ">=20.19.0 || ^22.12.0"
	},
	"scripts": {
		"build:renderer": "vite build",
		"build:electron": "tsc -p tsconfig.electron.json",
		"start:electron": "electron \"electron-dist/main.js\"",
		"dev": "concurrently -k \"vite\" \"npm run dev:electron\"",
		"dev:electron": "wait-on http://127.0.0.1:5173 && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron \"electron-dist/main.js\"",
		"preview": "npm run build:renderer && npm run build:electron && npm run start:electron"
	},
	"dependencies": {
		"@monaco-editor/react": "^4.7.0",
		"blockly": "^12.5.1",
		"electron": "^41.1.0",
		"electron-log": "^5.4.3",
		"electron-store": "^11.0.2",
		"monaco-editor": "^0.55.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router-dom": "^7.13.2",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"concurrently": "^9.2.1",
		"cross-env": "^10.1.0",
		"eslint": "^9.39.4",
		"prettier": "^3.8.1",
		"tsx": "^4.21.0",
		"typescript": "~5.6.0",
		"typescript-eslint": "^8.57.2",
		"vite": "^8.0.3",
		"wait-on": "^9.0.4"
	}
}
